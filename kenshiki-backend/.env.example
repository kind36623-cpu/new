# =========================================================
# Kenshiki Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# Set these as Environment Variables in the Render dashboard for production.
# =========================================================

# The Vercel frontend URL (used for CORS allow-list)
FRONTEND_URL=https://your-app.vercel.app

# Groq — LLM inference (https://console.groq.com/keys)
VITE_GROQ_API_KEY=your_groq_api_key_here

# NewsData.io — top news feed (https://newsdata.io/api-key)
VITE_NEWS_API_KEY=your_newsdata_key_here

# Tavily — normal web search (https://tavily.com)
VITE_TAVILY_API_KEY=your_tavily_key_here

# Serper — pro Google-level search (https://serper.dev)
VITE_SERPER_API_KEY=your_serper_key_here

# Pinecone — vector database (https://pinecone.io)
VITE_PINECONE_API_KEY=your_pinecone_key_here
VITE_PINECONE_INDEX=kenshiki-rag
